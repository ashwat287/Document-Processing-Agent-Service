# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/docprocessor

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM (LiteLLM model string — change provider by changing prefix)
# Examples: openai/gpt-4o-mini, anthropic/claude-sonnet-4-20250514, gemini/gemini-2.5-flash
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=your-api-key-here
# Optional: custom API base URL (for Azure OpenAI or self-hosted)
# LLM_API_BASE=

# Agent
MAX_TOKENS_PER_JOB=32000
MAX_DOCUMENT_SIZE=10485760
# Set to false if behind a corporate proxy with self-signed certs
SSL_VERIFY=true

# Worker
WORKER_CONCURRENCY=2

# Logging
LOG_LEVEL=INFO
